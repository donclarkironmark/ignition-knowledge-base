# GitHub Personal Access Token for fetching content from product-management repo
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shared password for KB access
KB_PASSWORD=your-shared-password

# Secret for signing session cookies (generate with: openssl rand -hex 32)
KB_SESSION_SECRET=your-random-32-char-secret

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
