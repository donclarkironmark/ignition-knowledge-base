# ─── Auth ────────────────────────────────────────────────────────────────────
# Shared password for viewer access
KB_PASSWORD=your-shared-password
# Optional: separate password that grants admin role (Insider admin, edit posts/editions)
KB_ADMIN_PASSWORD=your-admin-password
# Secret for signing session cookies — generate with: openssl rand -hex 32
KB_SESSION_SECRET=your-random-32-char-secret

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3001
APP_URL=http://localhost:3001

# ─── Supabase (Insider) ──────────────────────────────────────────────────────
# Reuse the existing Insider Supabase project values — same URL, anon and
# service-role keys used by the original product-management deployment.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─── AI (Insider "suggest insight" helper) ───────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Email (Insider digests, subscription confirmations, alerts) ─────────────
SMTP_USER=you@example.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=insider@example.com
SMTP_FROM_NAME=Ignition Insider

# ─── Tokens ──────────────────────────────────────────────────────────────────
# HMAC secret for subscription tokens (unsubscribe links) — keep stable
HMAC_SECRET=your-hmac-secret
# Bearer token used by Claude Code Routines to POST drafts into Insider
INSIDER_SERVICE_TOKEN=your-service-token
# Bearer token for the weekly digest cron endpoint
CRON_SECRET=your-cron-secret

# ─── Legacy (unused) ─────────────────────────────────────────────────────────
# GitHub PAT was for an older content-sync flow that's no longer in use.
# GITHUB_PAT=
